---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-car-lift.png';
import brakesImage from '../assets/images/brakes.jpeg';
import liftImage from '../assets/images/lift.png';
import trackCarImage from '../assets/images/track-car-wheel-service.jpg';
import acuraImage from '../assets/images/acura-suspension-service.jpg';
import tireMachineImage from '../assets/images/tire-machine-service.jpg';
import audiQ5Image from '../assets/images/audi-q5-service.jpg';

const galleryImages = [
  { image: trackCarImage, alt: 'Wheel service on a track-prepped car at Reliable Motorsports', caption: 'Track car wheel service' },
  { image: acuraImage, alt: 'Acura RDX on the lift for suspension and brake work', caption: 'Suspension and brake service' },
  { image: tireMachineImage, alt: 'Mounting a tire on an Audi wheel', caption: 'Tire mounting and balancing' },
  { image: audiQ5Image, alt: 'Audi Q5 in the shop for service', caption: 'Audi Q5 in for service' },
  { image: heroImage, alt: 'Car on a lift', caption: 'Shop bay setup' },
  { image: brakesImage, alt: 'Brake service in progress', caption: 'Brake service and inspection' },
  { image: liftImage, alt: 'Vehicle lift in the shop', caption: 'Professional shop equipment' },
];
---

<Layout title="Gallery" description="Browse photos from the shop and recent service work to see how Reliable Motorsports operates.">
  <main class="section">
    <div class="container">
      <div class="page-header reveal">
        <div class="eyebrow">Shop + Work Photos</div>
        <h1>Gallery</h1>
        <p>Browse photos from the shop and recent service work to see how Reliable Motorsports operates.</p>
      </div>

      <div class="gallery-mosaic">
        {galleryImages.map((item) => (
          <div class="gallery-item reveal">
            <Image src={item.image} alt={item.alt} width={640} height={480} />
            <p class="gallery-caption">{item.caption}</p>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
