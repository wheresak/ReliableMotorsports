---
import Layout from '../layouts/Layout.astro';
import { faqItems } from '../lib/faq';
---

<Layout title="FAQ" description="Answers to common questions about appointments, service areas, and how Reliable Motorsports operates.">
  <main class="section">
    <div class="container">
      <div class="page-header reveal">
        <div class="eyebrow">Frequently Asked Questions</div>
        <h1>FAQ</h1>
        <p>Answers to common questions about appointments, service areas, and how Reliable Motorsports operates.</p>
      </div>

      <div class="faq-list">
        {faqItems.map((item) => (
          <div class="faq-card reveal">
            <h2>{item.question}</h2>
            <p>{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </main>
</Layout>
