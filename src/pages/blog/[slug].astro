---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const isContactLink = post.data.relatedService === '/contact';
---

<Layout title={post.data.title} description={post.data.description}>
  <main class="section">
    <div class="container">
      <div class="page-header reveal">
        <div class="eyebrow">Blog</div>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
      </div>

      <article class="blog-article reveal">
        <Content />
      </article>

      <div class="service-cta reveal">
        <p>{isContactLink ? 'Have questions or ready to book?' : 'Ready to get this handled by Reliable Motorsports?'}</p>
        <a href={post.data.relatedService} class="btn btn-primary">
          {isContactLink ? 'Contact Us' : 'Book This Service'}
        </a>
      </div>

      <p class="back-link">
        <a href="/blog" class="text-link">Back to blog</a>
      </p>
    </div>
  </main>
</Layout>
