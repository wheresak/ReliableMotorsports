---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Blog" description="Insights, maintenance tips, and local automotive advice for Scarborough drivers and car enthusiasts.">
  <main class="section">
    <div class="container">
      <div class="page-header reveal">
        <div class="eyebrow">Blog</div>
        <h1>Blog</h1>
        <p>Insights, maintenance tips, and local automotive advice for Scarborough drivers and car enthusiasts.</p>
      </div>

      <div class="blog-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="card-link reveal">
            <article class="card">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </article>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
